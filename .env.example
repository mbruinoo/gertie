# Database (Neon PostgreSQL)
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# Payload
PAYLOAD_SECRET=your-secret-key-here

# Resend (transactional email — staff password resets only)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=no-reply@yourdomain.com

# Next.js public URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Playwright test credentials (never commit real values)
PLAYWRIGHT_TEST_EMAIL=
PLAYWRIGHT_TEST_PASSWORD=
PLAYWRIGHT_DEV_ADMIN_EMAIL=
PLAYWRIGHT_DEV_ADMIN_PASSWORD=
